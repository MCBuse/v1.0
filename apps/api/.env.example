# Server
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=mcbuse_dev

# Auth (Phase 2 — placeholders)
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# JWT
JWT_ACCESS_SECRET=change_me_in_production_min_32_chars
JWT_REFRESH_SECRET=change_me_in_production_different_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP (mock | twilio)
OTP_PROVIDER=mock
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# Solana (Phase 3 — placeholders)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_KEYPAIR_ENCRYPTION_KEY=change-me-32-byte-hex-key

# Adapters
ONRAMP_PROVIDER=mock
OFFRAMP_PROVIDER=mock
SWAP_PROVIDER=mock

# Circle (when ONRAMP_PROVIDER=circle)
CIRCLE_API_KEY=

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
