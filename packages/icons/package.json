{
  "name": "@repo/icons",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./assets/*": {
      "types": "./src/svg-module.d.ts",
      "default": "./assets/*"
    }
  },
  "typesVersions": {
    "*": {
      "assets/*": ["src/svg-module.d.ts"]
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "typescript": "5.9.2"
  }
}
